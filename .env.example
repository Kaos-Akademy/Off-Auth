# Browser (prefix required for Next.js client bundles)
NEXT_PUBLIC_CONVEX_URL=

# Convex dashboard / site URL (optional; not read by this app unless you wire it)
NEXT_PUBLIC_CONVEX_SITE_URL=

# Passkey RP — used by Convex actions (set in Convex env / deployment, not only here)
NEXT_PUBLIC_PASSKEY_RP_ID=localhost
NEXT_PUBLIC_PASSKEY_RP_NAME=Off Auth

# Flow (@onflow/react-sdk) — https://developers.flow.com/build/tools/react-sdk
NEXT_PUBLIC_FLOW_NETWORK=testnet
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_APP_ICON_URL=
